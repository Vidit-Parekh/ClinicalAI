# ══════════════════════════════════════════════════════════════
# ClinicalAI — .gitignore
# ══════════════════════════════════════════════════════════════

# ── MIMIC-III data — NEVER commit (PHI / licensed data) ────────
data/raw/
data/processed/
data/archive/

# ── Saved models — too large for git ───────────────────────────
# Root models folder
models/

# Per-phase model folders (created inside each phase directory)
phase2_nlp/models/
phase3_ml/models/
phase4_imaging/models/
phase5_llm/models/

# ── Phase outputs (regenerated by running the pipeline) ────────
phase1_data_pipeline/outputs/
phase2_nlp/outputs/
phase3_ml/outputs/
phase4_imaging/outputs/
phase5_llm/outputs/

# ── MLflow tracking (created inside phase directories) ─────────
mlruns/
mlartifacts/
phase2_nlp/mlruns/
phase3_ml/mlruns/

# ── Python cache (appears inside phase directories) ────────────
__pycache__/
phase2_nlp/__pycache__/
phase3_ml/__pycache__/
phase4_imaging/__pycache__/
phase5_llm/__pycache__/
phase6_dashboard/__pycache__/
phase6_dashboard/components/__pycache__/
phase6_dashboard/pages/__pycache__/
*.pyc
*.pyo
*.pyd

# ── HuggingFace model cache ─────────────────────────────────────
.cache/

# ── Environment ─────────────────────────────────────────────────
.env
venv/
env/
.venv/
.ipynb_checkpoints/

# ── Jupyter ─────────────────────────────────────────────────────
*.ipynb_checkpoints
.jupyter/

# ── Documentation images (local only) ──────────────────────────
documentation images/

# ── OS ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo